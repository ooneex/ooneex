{
  "name": "@ooneex/folder",
  "description": "Type definitions and utilities for folder/directory structures with status and color support",
  "version": "0.0.4",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "publish": "bun publish --tolerate-republish --access public"
  },
  "dependencies": {},
  "devDependencies": {
    "@ooneex/status": "workspace:*",
    "@ooneex/color": "workspace:*",
    "@ooneex/types": "workspace:*"
  }
}
