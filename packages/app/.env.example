# App configuration
APP_ENV="local"
DEBUG=true

# Logs configuration
LOGS_DATABASE_PATH="var/logs.db"

# Analytics configuration
ANALYTICS_POSTHOG_API_KEY=
ANALYTICS_POSTHOG_HOST="https://eu.i.posthog.com"

# Cache configuration
CACHE_REDIS_URL="redis://localhost:6379"

# Pub/Sub configuration
PUBSUB_REDIS_URL="redis://localhost:6379"

# Storage configuration
STORAGE_CLOUDFLARE_ACCESS_KEY=
STORAGE_CLOUDFLARE_SECRET_KEY=
STORAGE_CLOUDFLARE_ENDPOINT=
STORAGE_CLOUDFLARE_REGION="EEUR"
STORAGE_BUNNY_ACCESS_KEY=
STORAGE_BUNNY_STORAGE_ZONE=
STORAGE_BUNNY_REGION="de"

# Database configuration
DATABASE_URL="postgres://username:password@localhost:5432/database_name"
DATABASE_REDIS_URL=

# Mailer configuration
NODE_MAILER_DSN='smtp://localhost:1025'
MAILER_SENDER_NAME=
MAILER_SENDER_ADDRESS=
RESEND_API_KEY=

# JWT
JWT_SECRET=

# AI configuration
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
