{
  "name": "@ooneex/storage",
  "description": "File and object storage abstraction layer with support for local filesystem and cloud storage providers",
  "version": "0.0.4",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "publish": "bun publish --tolerate-republish --access public"
  },
  "dependencies": {
    "@ooneex/container": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-status": "workspace:*"
  },
  "keywords": [
    "blob",
    "bun",
    "cloud",
    "file-storage",
    "ooneex",
    "s3",
    "storage",
    "typescript"
  ]
}
