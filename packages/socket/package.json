{
  "name": "@ooneex/socket",
  "description": "WebSocket server implementation for real-time bidirectional communication",
  "version": "0.17.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --access public"
  },
  "devDependencies": {
    "@ooneex/controller": "workspace:*",
    "@ooneex/http-request": "workspace:*",
    "@ooneex/http-response": "workspace:*"
  },
  "keywords": [
    "bun",
    "ooneex",
    "realtime",
    "socket",
    "typescript",
    "websocket",
    "ws"
  ]
}
