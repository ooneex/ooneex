{
  "name": "ooneex",
  "private": true,
  "module": "index.ts",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun --workspaces run build",
    "fmt": "bunx biome format --write",
    "lint": "bunx biome lint",
    "test": "bun test tests",
    "test:watch": "bun test tests --watch",
    "publish": "bun --workspaces run publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.0",
    "@types/bun": "latest",
    "husky": "^9.1.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
