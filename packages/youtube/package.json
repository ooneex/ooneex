{
  "name": "@ooneex/youtube",
  "description": "A YouTube video downloader and utility library",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "publish": "bun publish --tolerate-republish --access public"
  },
  "dependencies": {
    "@ooneex/exception": "workspace:*",
    "ytdlp-nodejs": "^2.3.5"
  },
  "devDependencies": {
    "@ooneex/types": "workspace:*"
  },
  "peerDependencies": {}
}
