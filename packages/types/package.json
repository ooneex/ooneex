{
  "name": "@ooneex/types",
  "version": "0.0.1",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "compile": "tsc -p tsconfig.build.json",
    "test": "bun test tests",
    "test:watch": "bun test tests --watch",
    "build": "rm -rf dist && bun run compile && bun build ./src/index.ts --outdir ./dist --target browser --format esm --packages external --minify",
    "publish": "bun run build && bun publish --access public"
  },
  "dependencies": {
    "@ooneex/http-status": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-mimes": "workspace:*",
    "@ooneex/http-header": "workspace:*",
    "@ooneex/container": "workspace:*"
  },
  "peerDependencies": {},
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ]
}
