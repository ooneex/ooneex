{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "fmt": {
      "cache": true
    },
    "lint": {
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "cache": true
    }
  },
  "tui": {
    "autoExit": true
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "projectsAffectedByDependencyUpdates": "auto"
    }
  ],
  "packageManager": "bun",
  "namedInputs": {
    "sharedGlobals": [
      "{workspaceRoot}/.github/workflows/ci.yml"
    ],
    "default": [
      "sharedGlobals"
    ]
  },
  "analytics": false
}