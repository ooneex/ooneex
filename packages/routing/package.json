{
  "name": "@ooneex/routing",
  "version": "0.0.1",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "compile": "tsc ./src/index.ts --declaration --emitDeclarationOnly --outfile dist/index.d.ts",
    "build": "bun run compile && bun build ./src/index.ts --outdir ./dist --target browser --format esm --packages external --minify",
    "lint": "tsc --noEmit && bunx biome lint",
    "test": "bun test tests",
    "test:watch": "bun test tests --watch",
    "test:coverage": "bun test tests --coverage",
    "test:coverage:watch": "bun test tests --coverage --watch"
  },
  "devDependencies": {},
  "peerDependencies": {}
}
