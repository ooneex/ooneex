{
  "name": "@ooneex/mailer",
  "version": "1.1.14",
  "module": "./dist/index.js",
  "dependencies": {
    "@ooneex/app-env": "workspace:^",
    "@ooneex/container": "workspace:^",
    "@ooneex/exception": "workspace:^",
    "@ooneex/http-status": "workspace:^",
    "@ooneex/translation": "workspace:^",
    "resend": "^6.4.2"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "description": "Transactional email service supporting Nodemailer SMTP and Resend API \u2014 send templated emails with attachments and delivery tracking",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "bun",
    "email",
    "mail",
    "mailer",
    "nodemailer",
    "ooneex",
    "resend",
    "smtp",
    "typescript"
  ],
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --force --production --access public"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
