{
  "name": "@ooneex/education",
  "description": "Educational domain types and utilities including medical education support",
  "version": "0.0.4",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./medecine": {
      "import": {
        "types": "./dist/medecine/index.d.ts",
        "default": "./dist/medecine/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "build": "bunup",
    "test": "bun test",
    "lint": "tsgo --noEmit && bunx biome lint",
    "publish": "bun publish --tolerate-republish --access public"
  },
  "devDependencies": {
    "@ooneex/types": "workspace:*"
  }
}
