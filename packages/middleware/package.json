{
  "name": "@ooneex/middleware",
  "description": "Middleware framework with decorators for request/response pipeline processing in HTTP and WebSocket contexts",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "publish": "bun publish --tolerate-republish --access public"
  },
  "dependencies": {
    "@ooneex/container": "workspace:*"
  },
  "devDependencies": {
    "@ooneex/controller": "workspace:*",
    "@ooneex/socket": "workspace:*"
  }
}
