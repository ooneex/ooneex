{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "fmt": {
      "cache": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "publish": {
      "dependsOn": ["^publish"]
    },
    "nx-release-publish": {
      "dependsOn": ["build"],
      "options": {
        "packageRoot": "{projectRoot}"
      }
    }
  },
  "tui": {
    "autoExit": true
  },
  "release": {
    "projects": ["packages/*"],
    "projectsRelationship": "independent",
    "git": {
      "commitMessage": "chore(release): Release {projectName}-v{version}"
    },
    "version": {
      "conventionalCommits": true,
      "preVersionCommand": "bun run build",
      "fallbackCurrentVersionResolver": "disk",
      "versionPrefix": "auto"
    },
    "changelog": {
      "automaticFromRef": true,
      "projectChangelogs": {
        "file": false,
        "createRelease": "github"
      }
    }
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "projectsAffectedByDependencyUpdates": "auto"
    }
  ],
  "packageManager": "bun",
  "namedInputs": {
    "sharedGlobals": ["{workspaceRoot}/.github/workflows/ci.yml"],
    "default": ["sharedGlobals"]
  }
}
