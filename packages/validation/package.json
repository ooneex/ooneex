{
  "name": "@ooneex/validation",
  "description": "Type-safe validation framework powered by ArkType with built-in constraints and JSON schema support",
  "version": "0.0.16",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./constraints": {
      "import": {
        "types": "./dist/constraints/index.d.ts",
        "default": "./dist/constraints/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --access public"
  },
  "dependencies": {
    "@ooneex/app-env": "workspace:*",
    "@ooneex/currencies": "workspace:*",
    "@ooneex/translation": "workspace:*",
    "arktype": "^2.1.29"
  },
  "keywords": [
    "arktype",
    "bun",
    "constraints",
    "ooneex",
    "schema",
    "typescript",
    "validation",
    "validator"
  ]
}
