{
  "name": "@ooneex/ai",
  "description": "Unified AI client library with support for OpenAI, Anthropic, Google Gemini, and Ollama providers",
  "version": "0.0.17",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --access public",
    "test": "bun test tests"
  },
  "dependencies": {
    "@ooneex/container": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-status": "workspace:*",
    "@ooneex/validation": "workspace:*",
    "@tanstack/ai": "^0.2.0",
    "@tanstack/ai-anthropic": "^0.2.0",
    "@tanstack/ai-gemini": "^0.2.0",
    "@tanstack/ai-ollama": "^0.2.0",
    "@tanstack/ai-openai": "^0.2.0"
  },
  "devDependencies": {
    "@ooneex/translation": "workspace:*"
  },
  "keywords": [
    "ai",
    "anthropic",
    "artificial-intelligence",
    "bun",
    "gemini",
    "llm",
    "machine-learning",
    "ollama",
    "ooneex",
    "openai",
    "typescript"
  ]
}
