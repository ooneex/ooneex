{
  "name": "@ooneex/http-response",
  "description": "HTTP response builder with status codes, headers, cookies, and content formatting support",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "compile": "tsc ./src/index.ts --declaration --emitDeclarationOnly --target ES2022 --moduleResolution bundler --outfile dist/index.d.ts",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "publish": "bun publish --tolerate-republish --access public",
    "test": "bun test tests"
  },
  "dependencies": {
    "@ooneex/app-env": "workspace:*",
    "@ooneex/http-header": "workspace:*",
    "@ooneex/http-status": "workspace:*"
  },
  "devDependencies": {}
}
