{
  "name": "@ooneex/cli",
  "description": "Interactive CLI toolkit for scaffolding Ooneex projects, modules, controllers, services, repositories, and more with customizable code generation templates",
  "version": "1.13.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ooneex": "./dist/index.js",
    "oo": "./dist/index.js"
  },
  "keywords": [
    "bun",
    "cli",
    "code-generator",
    "command-line",
    "console",
    "ooneex",
    "scaffolding",
    "terminal",
    "typescript"
  ],
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --force --production --access public"
  },
  "dependencies": {
    "@logtail/node": "^0.5.8",
    "@ooneex/ai": "^1.1.2",
    "@ooneex/analytics": "^1.1.2",
    "@ooneex/cache": "^1.1.2",
    "@ooneex/command": "workspace:*",
    "@ooneex/container": "workspace:*",
    "@ooneex/controller": "^1.3.0",
    "@ooneex/cron": "^1.1.2",
    "@ooneex/database": "^1.1.2",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-status": "workspace:*",
    "@ooneex/logger": "^1.2.2",
    "@ooneex/mailer": "^1.1.2",
    "@ooneex/middleware": "^1.2.2",
    "@ooneex/migrations": "workspace:*",
    "@ooneex/module": "^1.2.2",
    "@ooneex/permission": "^1.1.2",
    "@ooneex/repository": "^1.1.2",
    "@ooneex/routing": "workspace:*",
    "@ooneex/seeds": "workspace:*",
    "@ooneex/service": "^1.1.2",
    "@ooneex/storage": "^1.1.2",
    "@ooneex/translation": "workspace:*",
    "@ooneex/utils": "workspace:*",
    "@ooneex/validation": "workspace:*"
  },
  "devDependencies": {
    "@ooneex/types": "workspace:*"
  }
}
