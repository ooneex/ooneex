{
  "name": "@ooneex/app",
  "description": "Core application framework for building modern web applications with Bun, providing routing, middleware, caching, logging, and more",
  "version": "0.16.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --access public",
    "dev": "bun run src/dev.ts"
  },
  "dependencies": {
    "@ooneex/analytics": "workspace:*",
    "@ooneex/app-env": "workspace:*",
    "@ooneex/cache": "workspace:*",
    "@ooneex/container": "workspace:*",
    "@ooneex/database": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-request": "workspace:*",
    "@ooneex/http-response": "workspace:*",
    "@ooneex/http-status": "workspace:*",
    "@ooneex/logger": "workspace:*",
    "@ooneex/mailer": "workspace:*",
    "@ooneex/rate-limit": "workspace:*",
    "@ooneex/role": "workspace:*",
    "@ooneex/routing": "workspace:*",
    "@ooneex/storage": "workspace:*",
    "@ooneex/utils": "workspace:*",
    "@ooneex/validation": "workspace:*"
  },
  "devDependencies": {
    "@ooneex/controller": "workspace:*",
    "@ooneex/cron": "workspace:*",
    "@ooneex/middleware": "workspace:*",
    "@ooneex/module": "workspace:*",
    "@ooneex/socket": "workspace:*",
    "@ooneex/translation": "workspace:*",
    "@ooneex/types": "workspace:*"
  },
  "keywords": [
    "application",
    "bun",
    "framework",
    "ooneex",
    "typescript",
    "web-app"
  ]
}
