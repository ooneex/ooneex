{
  "name": "@ooneex/cli",
  "version": "0.16.0",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ooneex": "./dist/index.js",
    "@ooneex/cli": "./dist/index.js"
  },
  "description": "CLI tool for scaffolding Ooneex applications, modules, controllers, services, and more",
  "keywords": [
    "bun",
    "cli",
    "code-generator",
    "command-line",
    "console",
    "ooneex",
    "scaffolding",
    "terminal",
    "typescript"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --access public"
  },
  "type": "module",
  "dependencies": {
    "@ooneex/translation": "workspace:*",
    "@ooneex/http-status": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/validation": "workspace:*",
    "@ooneex/seeds": "workspace:*",
    "@ooneex/migrations": "workspace:*",
    "@ooneex/container": "workspace:*",
    "@ooneex/utils": "workspace:*",
    "@ooneex/routing": "workspace:*",
    "@ooneex/logger": "workspace:*"
  },
  "devDependencies": {
    "@ooneex/types": "workspace:*"
  }
}
