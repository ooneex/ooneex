{
  "name": "@ooneex/mailer",
  "description": "Email sending service with support for Nodemailer SMTP and Resend API for transactional emails",
  "version": "0.0.4",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "publish": "bun publish --tolerate-republish --access public"
  },
  "dependencies": {
    "@ooneex/container": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-status": "workspace:*",
    "nodemailer": "^7.0.10",
    "resend": "^6.4.2"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.4"
  }
}
