{
  "name": "@ooneex/routing",
  "description": "Flexible HTTP routing system with decorator-based route definitions, validation support, and permission handling",
  "version": "0.17.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --access public"
  },
  "dependencies": {
    "@ooneex/container": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-status": "workspace:*",
    "@ooneex/validation": "workspace:*"
  },
  "devDependencies": {
    "@ooneex/app-env": "workspace:*",
    "@ooneex/controller": "workspace:*",
    "@ooneex/http-response": "workspace:*",
    "@ooneex/permission": "workspace:*",
    "@ooneex/role": "workspace:*",
    "@ooneex/translation": "workspace:*",
    "@ooneex/types": "workspace:*"
  },
  "keywords": [
    "bun",
    "decorator",
    "http",
    "ooneex",
    "router",
    "routes",
    "routing",
    "typescript"
  ]
}
