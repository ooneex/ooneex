{
  "name": "@ooneex/cli",
  "version": "0.3.0",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ooneex": "./dist/index.js",
    "@ooneex/cli": "./dist/index.js"
  },
  "description": "CLI tool for scaffolding Ooneex applications, modules, controllers, services, and more",
  "keywords": [
    "bun",
    "cli",
    "code-generator",
    "command-line",
    "console",
    "ooneex",
    "scaffolding",
    "terminal",
    "typescript"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "publish": "bun publish --tolerate-republish --access public",
    "locales:clean": "wuchale --clean",
    "locales:watch": "wuchale --watch",
    "locales:generate": "wuchale"
  },
  "type": "module"
}
