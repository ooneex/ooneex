{
  "name": "@ooneex/analytics",
  "version": "1.1.3",
  "module": "./dist/index.js",
  "dependencies": {
    "@ooneex/app-env": "workspace:*",
    "@ooneex/container": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-status": "workspace:*",
    "posthog-node": "^5.11.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
