{
  "name": "@ooneex/url",
  "description": "URL parsing, manipulation, and query string utilities for web applications",
  "version": "0.17.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --access public"
  },
  "dependencies": {
    "@ooneex/utils": "workspace:*"
  },
  "devDependencies": {
    "@ooneex/types": "workspace:*",
    "@ooneex/translation": "workspace:*"
  },
  "keywords": [
    "bun",
    "ooneex",
    "path",
    "query-string",
    "routing",
    "typescript",
    "uri",
    "url"
  ]
}
