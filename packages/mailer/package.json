{
  "name": "@ooneex/mailer",
  "version": "0.0.19",
  "module": "./dist/index.js",
  "dependencies": {
    "@ooneex/container": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-status": "workspace:*",
    "@ooneex/translation": "workspace:*",
    "resend": "^6.4.2"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
