{
  "name": "@ooneex/http-response",
  "description": "",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "compile": "tsc ./src/index.ts --declaration --emitDeclarationOnly --target ES2022 --moduleResolution bundler --outfile dist/index.d.ts",
    "build": "bunup",
    "publish": "bun run build && bun publish --access public"
  },
  "dependencies": {
    "@ooneex/http-status": "workspace:*",
    "@ooneex/http-header": "workspace:*"
  },
  "devDependencies": {},
  "peerDependencies": {}
}
