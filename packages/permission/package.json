{
  "name": "@ooneex/permission",
  "description": "Fine-grained access control using CASL — define, evaluate, and enforce ability-based permissions with role and resource scoping",
  "version": "1.1.6",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --force --production --access public"
  },
  "dependencies": {
    "@casl/ability": "^6.7.3",
    "@ooneex/container": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-status": "workspace:*"
  },
  "devDependencies": {
    "@ooneex/user": "workspace:*"
  },
  "keywords": [
    "authorization",
    "bun",
    "casl",
    "ooneex",
    "permission",
    "permissions",
    "rbac",
    "typescript"
  ]
}
