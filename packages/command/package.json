{
  "name": "@ooneex/command",
  "description": "Command framework for building CLI commands with dependency injection, argument parsing, and execution logging",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --force --production --access public"
  },
  "dependencies": {
    "@ooneex/container": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-status": "workspace:*",
    "@ooneex/logger": "workspace:*",
    "@ooneex/utils": "workspace:*"
  },
  "devDependencies": {
    "@ooneex/types": "workspace:*"
  },
  "keywords": [
    "bun",
    "cli",
    "command",
    "ooneex",
    "typescript"
  ]
}
