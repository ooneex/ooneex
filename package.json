    "@commitlint/prompt-cli": "^20.2.0",
    "@commitlint/types": "^20.3.1",
    "@nx/js": "^22.2.0",
    "@nx/workspace": "^22.2.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.3",
    "@swc/helpers": "~0.5.17",
    "@types/bun": "1.3.11",
    "@types/node": "^24.10.3",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
