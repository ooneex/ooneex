{
  "name": "@ooneex/payment",
  "description": "Payment and pricing type definitions with currency handling, product categorization, and billing metadata for e-commerce integrations",
  "version": "1.0.2",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --force --production --access public"
  },
  "dependencies": {
    "@ooneex/app-env": "workspace:*",
    "@ooneex/container": "workspace:*",
    "@ooneex/exception": "workspace:*",
    "@ooneex/http-status": "workspace:*",
    "@polar-sh/sdk": "^0.30.0"
  },
  "devDependencies": {
    "@ooneex/currencies": "workspace:*",
    "@ooneex/types": "workspace:*"
  },
  "keywords": [
    "billing",
    "bun",
    "e-commerce",
    "ooneex",
    "payment",
    "payments",
    "pricing",
    "typescript"
  ]
}
