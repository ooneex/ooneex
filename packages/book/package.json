{
  "name": "@ooneex/book",
  "description": "Book entity types and interfaces for managing digital book content with categories, tags, and status tracking",
  "version": "0.0.4",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "publish": "bun publish --tolerate-republish --access public",
    "test": "bun test tests"
  },
  "dependencies": {},
  "devDependencies": {
    "@ooneex/category": "workspace:*",
    "@ooneex/status": "workspace:*",
    "@ooneex/tag": "workspace:*",
    "@ooneex/types": "workspace:*"
  },
  "keywords": [
    "book",
    "bun",
    "ebook",
    "ooneex",
    "publishing",
    "typescript"
  ]
}
